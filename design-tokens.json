  "motion": {
    "$philosophy": [
      "Aligned to @zpi/z-taste (ZaloPay production lib): pure CSS/tween cubic-bezier, NO JS spring — z-taste uses no spring configs at all.",
      "1. Curves come straight from z-taste. `out` (0.04,0.62,0.23,0.98) is the primary UI curve there — used for most content/opacity/keyboard motion.",
      "2. Keep UI motion short — mostly <=300ms; only the large drawer/screen push reaches 400ms. Faster reads as more responsive.",
      "3. `drawer` (0.32,0.72,0,1) matches z-taste's DrawerBottomSheet exactly; `standard` (0.4,0,0.2,1) matches its number-display motion.",
      "4. enter/exit curves are z-taste's keyboard-section variants — asymmetric (different in vs out).",
      "5. Only animate transform and opacity (perf). Tokens carry duration + easing only."
    ],
    "duration": {
      "instant": "100ms",
      "fast": "200ms",
      "normal": "300ms",
      "slow": "400ms"
    },
    "durationUse": {
      "instant": "key press, cursor move, micro tactile feedback",
      "fast": "opacity/fade, tags, small transitions (z-taste base 0.2s)",
      "normal": "keyboard/content/overlay, most transitions (z-taste 0.3s)",
      "slow": "drawer / screen push (z-taste drawer 0.4s)"
    },
    "easing": {
      "out": "cubic-bezier(0.04, 0.62, 0.23, 0.98)",
      "enter": "cubic-bezier(0.25, 0.46, 0.45, 0.94)",
      "exit": "cubic-bezier(0.55, 0.085, 0.68, 0.53)",
      "drawer": "cubic-bezier(0.32, 0.72, 0, 1)",
      "standard": "cubic-bezier(0.4, 0, 0.2, 1)"
    },
    "easingUse": {
      "out": "DEFAULT: content, opacity, press, most UI (z-taste primary curve)",
      "enter": "elements appearing with y/scale (z-taste keyboard-section enter)",
      "exit": "elements leaving (z-taste keyboard-section exit)",
      "drawer": "sheet/drawer slide-up, present, image viewer (z-taste drawer)",
      "standard": "number/value change, on-screen reposition (z-taste number display)"
    }
  },
